DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/emergency_scheduling
REDIS_URL=redis://redis:6379/0
AUTO_SEED_DEFAULTS=true

# Browser-facing API URL used by Next.js.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api

# Optional OpenAI-compatible report generation.
# Leave empty to use deterministic template fallback.
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=deepseek-chat

